# Vorlage — kopiere diese Datei nach ".env" und trage deinen Schlüssel ein:
#   cp .env.example .env
# Die .env selbst wird NICHT eingecheckt (siehe .gitignore).

# Google Gemini API-Key (Pflicht für echte Entwürfe)
GOOGLE_API_KEY=dein-google-api-key-hier

# Modellname (Bindestriche + Dezimalpunkt beachten!)
# lite = leichter/günstiger, eigenes Gratis-Tageslimit. Alternativ: gemini-2.5-flash
MODEL_NAME=gemini-2.5-flash-lite

# Lernphase: solange "true", geht JEDE Antwort zur menschlichen Freigabe.
LERNPHASE=true

# Kreativität: 0 = immer gleich/steif, ~1 = abwechslungsreich/menschlich.
# Höher = "Neu generieren" bringt echte Varianten und natürlicherer Ton.
TEMPERATURE=0.85
