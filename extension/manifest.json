{
  "manifest_version": 3,
  "name": "Kudora – Antworten auf Google-Bewertungen",
  "version": "0.1.0",
  "description": "Erzeugt mit einem Klick professionelle, persönliche Antworten auf Google-Bewertungen – direkt auf der Bewertungsseite.",
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "permissions": ["storage", "clipboardWrite"],
  "host_permissions": [
    "http://localhost/*",
    "http://127.0.0.1/*",
    "https://*/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "https://business.google.com/*",
        "https://www.google.com/*",
        "http://localhost/*",
        "http://127.0.0.1/*"
      ],
      "js": ["selectors.js", "content.js"],
      "css": ["content.css"],
      "run_at": "document_idle"
    }
  ]
}
